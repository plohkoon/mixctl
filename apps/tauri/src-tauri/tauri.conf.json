{
  "productName": "MixCtl",
  "version": "0.1.0",
  "identifier": "dev.greghuber.MixCtl",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MixCtl",
        "width": 750,
        "height": 450,
        "minWidth": 600,
        "minHeight": 350
      },
      {
        "label": "applet",
        "title": "MixCtl Applet",
        "url": "/applet",
        "width": 360,
        "height": 600,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "closable": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Audio mixer for Linux with PipeWire routing",
    "longDescription": "MixCtl is a Linux audio mixer that creates virtual PipeWire inputs and outputs, letting you route and mix application audio with per-route volume and mute control. Includes DSP processing (EQ, gate, de-esser, compressor, limiter) and hardware integration for Beacn Mix devices.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "desktopTemplate": "mixctl.desktop"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
