import { Button } from "std-widgets.slint";
import { RouteStrip, StreamData } from "route_strip.slint";
import { StreamColumn } from "stream_column.slint";
import { Sidebar, SidebarOutput } from "sidebar.slint";
import { RulesDialog, AppRuleData } from "rules_dialog.slint";
import { CaptureDialog, CaptureDeviceData } from "capture_dialog.slint";
import { BeacnDialog } from "beacn_dialog.slint";

export { SidebarOutput, StreamData, RulesDialog, AppRuleData, CaptureDialog, CaptureDeviceData, BeacnDialog }

export struct RouteData {
    input-id: int,
    output-id: int,
    volume: int,
    muted: bool,
    input-name: string,
    input-color: color,
}

export global MixerState {
    in-out property <[SidebarOutput]> outputs;
    in-out property <[string]> input-names;
    in-out property <[string]> playback-device-names;
    in-out property <[RouteData]> routes;
    in-out property <[StreamData]> streams;
    in-out property <int> selected-output-id;
    in-out property <bool> audio-connected;
    in-out property <int> default-input-index;
    in-out property <int> picking-stream-id: 0;

    callback set-route-volume(int, int, int);
    callback set-route-mute(int, int, bool);
    callback select-output(int);
    callback set-output-target(int, int);  // output_id, device_index
    callback assign-stream(int, int, bool);
    callback set-default-input(int);
    callback open-rules-dialog();
    callback open-capture-dialog();
    callback open-beacn-dialog();
}

export component MainWindow inherits Window {
    title: "MixCtl";
    width: 750px;
    height: 450px;

    VerticalLayout {
        // Header
        Rectangle {
            height: 44px;
            background: #2c3e5080;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                Text {
                    text: "MixCtl";
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Text {
                    text: MixerState.audio-connected ? "●" : "○";
                    color: MixerState.audio-connected ? #2ecc71 : #e74c3c;
                    font-size: 14px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Button {
                    text: "Rules";
                    clicked => { MixerState.open-rules-dialog(); }
                }

                Button {
                    text: "Devices";
                    clicked => { MixerState.open-capture-dialog(); }
                }

                Button {
                    text: "Beacn";
                    clicked => { MixerState.open-beacn-dialog(); }
                }
            }
        }

        // Main content
        HorizontalLayout {
            vertical-stretch: 1;

            Sidebar {
                outputs: MixerState.outputs;
                input-names: MixerState.input-names;
                playback-device-names: MixerState.playback-device-names;
                selected-output-id: MixerState.selected-output-id;
                default-input-index: MixerState.default-input-index;

                output-selected(id) => {
                    MixerState.select-output(id);
                }
                default-input-changed(idx) => {
                    MixerState.set-default-input(idx);
                }
                output-target-changed(output-id, device-idx) => {
                    MixerState.set-output-target(output-id, device-idx);
                }
            }

            // Separator
            Rectangle {
                width: 1px;
                background: #555;
            }

            // Right side: strips above, streams below
            VerticalLayout {
                horizontal-stretch: 1;

                // Route strips
                HorizontalLayout {
                    padding: 12px;
                    spacing: 12px;
                    alignment: center;

                    for route in MixerState.routes: RouteStrip {
                        input-id: route.input-id;
                        output-id: route.output-id;
                        name: route.input-name;
                        channel-color: route.input-color;
                        volume: route.volume;
                        muted: route.muted;
                        picking-stream-id: MixerState.picking-stream-id;

                        volume-changed(iid, oid, vol) => {
                            MixerState.set-route-volume(iid, oid, vol);
                        }
                        mute-toggled(iid, oid, m) => {
                            MixerState.set-route-mute(iid, oid, m);
                        }
                        stream-dropped(pw-id, input-id) => {
                            MixerState.assign-stream(pw-id, input-id, true);
                            MixerState.picking-stream-id = 0;
                        }
                    }
                }

                // Separator
                Rectangle {
                    height: 1px;
                    background: #555;
                }

                // Streams area — full width, one column per input
                Rectangle {
                    height: 100px;
                    clip: true;

                    HorizontalLayout {
                        padding: 4px;
                        spacing: 4px;

                        for route in MixerState.routes: StreamColumn {
                            input-id: route.input-id;
                            input-name: route.input-name;
                            input-color: route.input-color;
                            all-streams: MixerState.streams;
                            picking-stream-id: MixerState.picking-stream-id;

                            stream-picked(pw-id) => {
                                MixerState.picking-stream-id = pw-id;
                            }
                            stream-dropped(pw-id, input-id) => {
                                MixerState.assign-stream(pw-id, input-id, true);
                                MixerState.picking-stream-id = 0;
                            }
                        }
                    }
                }
            }
        }
    }
}
