import { StreamCard } from "stream_card.slint";
import { StreamData } from "route_strip.slint";

export component StreamColumn inherits Rectangle {
    in property <int> input-id;
    in property <string> input-name;
    in property <color> input-color;
    in property <[StreamData]> all-streams;
    in property <int> picking-stream-id;

    callback stream-picked(int);
    callback stream-dropped(int, int);

    horizontal-stretch: 1;
    border-radius: 4px;
    border-width: root.picking-stream-id != 0 ? 1px : 0px;
    border-color: root.picking-stream-id != 0 ? #f39c1260 : transparent;

    // Drop zone
    TouchArea {
        clicked => {
            if root.picking-stream-id != 0 {
                root.stream-dropped(root.picking-stream-id, root.input-id);
            }
        }
        mouse-cursor: root.picking-stream-id != 0 ? pointer : default;
    }

    VerticalLayout {
        padding: 4px;
        spacing: 2px;

        // Header
        Text {
            text: root.input-name;
            font-weight: 700;
            font-size: 10px;
            color: root.input-color;
            horizontal-alignment: center;
        }

        // Stream cards
        for stream in root.all-streams: StreamCard {
            visible: stream.input-id == root.input-id;
            height: stream.input-id == root.input-id ? 22px : 0;
            pw-node-id: stream.pw-node-id;
            app-name: stream.app-name;
            input-color: stream.input-color;
            picked: stream.pw-node-id == root.picking-stream-id;

            clicked => {
                if root.picking-stream-id == stream.pw-node-id {
                    root.stream-picked(0);
                } else if root.picking-stream-id != 0 {
                    root.stream-dropped(root.picking-stream-id, root.input-id);
                } else {
                    root.stream-picked(stream.pw-node-id);
                }
            }
        }
    }
}
