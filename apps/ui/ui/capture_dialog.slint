import { Button, LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct CaptureDeviceData {
    pw-node-id: int,
    name: string,
    device-name: string,
    is-added: bool,
    input-id: int,
}

export component CaptureDialog inherits Window {
    title: "Capture Devices";
    width: 480px;
    height: 380px;

    in property <[CaptureDeviceData]> devices;

    callback add-capture(int, string, string);  // pw_node_id, name, color
    callback close-requested();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        ScrollView {
            vertical-stretch: 1;

            VerticalBox {
                spacing: 4px;

                if root.devices.length == 0: Text {
                    text: "No capture devices found";
                    horizontal-alignment: center;
                    color: #888;
                }

                for dev[idx] in root.devices: Rectangle {
                    height: 56px;
                    border-radius: 4px;
                    background: Math.mod(idx, 2) == 0 ? #ffffff08 : transparent;

                    HorizontalLayout {
                        padding: 8px;
                        spacing: 8px;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;

                            Text {
                                text: dev.name;
                                font-weight: 700;
                                font-size: 13px;
                            }

                            Text {
                                text: dev.device-name;
                                color: #888;
                                font-size: 11px;
                            }
                        }

                        if dev.is-added: Text {
                            text: "Added";
                            color: #888;
                            vertical-alignment: center;
                        }

                        if !dev.is-added: Button {
                            text: "Add";
                            clicked => {
                                root.add-capture(dev.pw-node-id, dev.name, "#4A90D9");
                            }
                        }
                    }
                }
            }
        }
    }
}
