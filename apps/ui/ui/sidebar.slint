import { ComboBox, VerticalBox } from "std-widgets.slint";

export struct SidebarOutput {
    id: int,
    name: string,
    color: color,
    target-device-index: int,
}

export component Sidebar inherits Rectangle {
    in property <[SidebarOutput]> outputs;
    in property <[string]> input-names;
    in property <[string]> playback-device-names;
    in property <int> selected-output-id;
    in property <int> default-input-index;

    callback output-selected(int);
    callback default-input-changed(int);
    callback output-target-changed(int, int);  // output_id, device_index

    width: 220px;
    horizontal-stretch: 0;

    VerticalBox {
        padding: 8px;
        spacing: 4px;

        Text {
            text: "Default Input";
            font-weight: 700;
            font-size: 13px;
        }

        ComboBox {
            model: root.input-names;
            current-index: root.default-input-index;
            selected(val) => {
                root.default-input-changed(self.current-index);
            }
        }

        Rectangle {
            height: 1px;
            background: #555;
        }

        Text {
            text: "Outputs";
            font-weight: 700;
            font-size: 13px;
        }

        VerticalLayout {
            vertical-stretch: 1;
            spacing: 4px;

            for out in root.outputs: VerticalLayout {
                spacing: 2px;

                Rectangle {
                    height: 36px;
                    border-radius: 6px;
                    background: out.id == root.selected-output-id ? #3498db40 : transparent;

                    TouchArea {
                        clicked => {
                            root.output-selected(out.id);
                        }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;

                        Text {
                            text: out.id == root.selected-output-id ? "●" : "○";
                            color: out.color;
                            vertical-alignment: center;
                            font-size: 14px;
                        }

                        Text {
                            text: out.name;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            font-size: 13px;
                        }
                    }
                }

                // Hardware target dropdown
                ComboBox {
                    model: root.playback-device-names;
                    current-index: out.target-device-index;
                    selected(val) => {
                        root.output-target-changed(out.id, self.current-index);
                    }
                }
            }

            // Spacer to push items to top
            Rectangle {
                vertical-stretch: 1;
            }
        }
    }
}
