import { Button, Slider, CheckBox, ComboBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct EqBandData {
    band-type-index: int,   // 0=low_shelf, 1=peaking, 2=high_shelf
    frequency: float,       // 20-20000 Hz
    gain-db: float,         // -24 to +24
    q: float,               // 0.1 to 18
}

export struct GateData {
    enabled: bool,
    threshold-db: float,    // -80 to 0
    attack-ms: float,       // 0.1 to 100
    release-ms: float,      // 1 to 2000
    hold-ms: float,         // 0 to 500
}

export struct DeesserData {
    enabled: bool,
    frequency: float,       // 2000 to 16000
    threshold-db: float,    // -60 to 0
    ratio: float,           // 1 to 20
}

export struct CompressorData {
    enabled: bool,
    threshold-db: float,    // -60 to 0
    ratio: float,           // 1 to 20
    attack-ms: float,       // 0.1 to 200
    release-ms: float,      // 1 to 2000
    makeup-gain-db: float,  // 0 to 30
    knee-db: float,         // 0 to 12
}

export struct LimiterData {
    enabled: bool,
    ceiling-db: float,      // -12 to 0
    release-ms: float,      // 1 to 500
}

component LabeledSlider inherits HorizontalBox {
    in property <string> label;
    in property <float> minimum;
    in property <float> maximum;
    in-out property <float> value;
    in property <string> suffix;
    in property <bool> enabled: true;

    callback changed(float);

    spacing: 8px;
    height: 32px;

    Text {
        text: root.label;
        width: 100px;
        vertical-alignment: center;
        font-size: 12px;
        color: root.enabled ? #ddd : #666;
    }

    Slider {
        horizontal-stretch: 1;
        minimum: root.minimum;
        maximum: root.maximum;
        value: root.value;
        enabled: root.enabled;
        changed(val) => {
            root.value = val;
            root.changed(val);
        }
    }

    Text {
        text: "\{Math.round(root.value * 10) / 10}" + root.suffix;
        width: 70px;
        vertical-alignment: center;
        font-size: 11px;
        color: root.enabled ? #aaa : #555;
        horizontal-alignment: right;
    }
}

component SectionHeader inherits Rectangle {
    in property <string> title;

    height: 28px;

    HorizontalLayout {
        padding-left: 4px;
        Text {
            text: root.title;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
            color: #e8e8e8;
        }
    }
}

export component DspDialog inherits Window {
    title: "DSP Processing";
    width: 580px;
    height: 930px;

    // Input selection
    in property <[string]> input-names;
    in-out property <int> selected-input-index: 0;

    // Output selection
    in property <[string]> output-names;
    in-out property <int> selected-output-index: 0;

    // EQ state (8 bands)
    in-out property <bool> eq-enabled;
    in-out property <[EqBandData]> eq-bands;

    // EQ frequency response curve image
    in property <image> eq-curve-image;

    // Gate state
    in-out property <GateData> gate;

    // De-esser state
    in-out property <DeesserData> deesser;

    // Compressor state
    in-out property <CompressorData> compressor;

    // Limiter state
    in-out property <LimiterData> limiter;

    // Callbacks
    callback input-selected(int);
    callback output-selected(int);

    callback eq-enabled-changed(bool);
    callback eq-band-changed(int, int, float, float, float);  // band_index, type_index, freq, gain, q
    callback reset-eq();

    callback gate-enabled-changed(bool);
    callback gate-changed(float, float, float, float);  // threshold, attack, release, hold

    callback deesser-enabled-changed(bool);
    callback deesser-changed(float, float, float);  // freq, threshold, ratio

    callback compressor-enabled-changed(bool);
    callback compressor-changed(float, float, float, float, float, float);  // threshold, ratio, attack, release, makeup, knee

    callback limiter-enabled-changed(bool);
    callback limiter-changed(float, float);  // ceiling, release

    callback close-requested();

    VerticalBox {
        padding: 12px;
        spacing: 4px;

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 4px;
                padding-right: 12px;

                // ===== INPUT DSP SECTION =====
                SectionHeader { title: "Input DSP"; }

                HorizontalBox {
                    spacing: 8px;
                    height: 32px;

                    Text {
                        text: "Input:";
                        vertical-alignment: center;
                        width: 60px;
                    }

                    input-combo := ComboBox {
                        model: root.input-names;
                        current-index: root.selected-input-index;
                        selected(val) => {
                            root.selected-input-index = self.current-index;
                            root.input-selected(self.current-index);
                        }
                    }
                }

                // --- EQ ---
                SectionHeader { title: "Equalizer"; }

                HorizontalBox {
                    spacing: 8px;
                    height: 28px;

                    CheckBox {
                        text: "Enable EQ";
                        checked: root.eq-enabled;
                        toggled => {
                            root.eq-enabled = self.checked;
                            root.eq-enabled-changed(self.checked);
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Button {
                        text: "Reset EQ";
                        clicked => { root.reset-eq(); }
                    }
                }

                // EQ frequency response curve
                Rectangle {
                    height: 230px;
                    clip: true;

                    // Curve image
                    Image {
                        source: root.eq-curve-image;
                        y: 14px;
                        height: 200px;
                        width: parent.width;
                        image-fit: fill;
                    }

                    // dB labels (left side)
                    Text {
                        x: 4px;
                        y: 2px;
                        text: "+24dB";
                        font-size: 9px;
                        color: #777;
                    }
                    Text {
                        x: 4px;
                        y: 14px + 100px - 6px;
                        text: "0dB";
                        font-size: 9px;
                        color: #999;
                    }
                    Text {
                        x: 4px;
                        y: 14px + 200px - 12px;
                        text: "-24dB";
                        font-size: 9px;
                        color: #777;
                    }

                    // Frequency labels (bottom)
                    Text {
                        x: 0px;
                        y: 216px;
                        text: "20";
                        font-size: 9px;
                        color: #777;
                    }
                    // 100Hz: log10(100)=2, log10(20)=1.301, range=log10(20000)-log10(20)=3.0, pos=(2-1.301)/3.0 = 0.233
                    Text {
                        x: parent.width * 23.3% - 8px;
                        y: 216px;
                        text: "100";
                        font-size: 9px;
                        color: #777;
                    }
                    // 1kHz: (3-1.301)/3.0 = 0.566
                    Text {
                        x: parent.width * 56.6% - 6px;
                        y: 216px;
                        text: "1k";
                        font-size: 9px;
                        color: #777;
                    }
                    // 10kHz: (4-1.301)/3.0 = 0.900
                    Text {
                        x: parent.width * 90.0% - 8px;
                        y: 216px;
                        text: "10k";
                        font-size: 9px;
                        color: #777;
                    }
                    // 20kHz at the right edge
                    Text {
                        x: parent.width - 22px;
                        y: 216px;
                        text: "20k";
                        font-size: 9px;
                        color: #777;
                    }
                }

                for band[band-idx] in root.eq-bands: VerticalLayout {
                    spacing: 2px;

                    HorizontalBox {
                        spacing: 8px;
                        height: 28px;

                        Text {
                            text: "Band \{band-idx + 1}";
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                            width: 60px;
                            color: root.eq-enabled ? #ccc : #666;
                        }

                        Text {
                            text: "Type:";
                            font-size: 12px;
                            vertical-alignment: center;
                            color: root.eq-enabled ? #ccc : #666;
                        }

                        band-type-combo := ComboBox {
                            model: ["low_shelf", "peaking", "high_shelf"];
                            current-index: band.band-type-index;
                            enabled: root.eq-enabled;
                            selected(val) => {
                                root.eq-band-changed(band-idx, self.current-index, band.frequency, band.gain-db, band.q);
                            }
                        }
                    }

                    LabeledSlider {
                        label: "  Freq (Hz)";
                        minimum: 20;
                        maximum: 20000;
                        value: band.frequency;
                        suffix: " Hz";
                        enabled: root.eq-enabled;
                        changed(val) => {
                            root.eq-band-changed(band-idx, band.band-type-index, val, band.gain-db, band.q);
                        }
                    }

                    LabeledSlider {
                        label: "  Gain (dB)";
                        minimum: -24;
                        maximum: 24;
                        value: band.gain-db;
                        suffix: " dB";
                        enabled: root.eq-enabled;
                        changed(val) => {
                            root.eq-band-changed(band-idx, band.band-type-index, band.frequency, val, band.q);
                        }
                    }

                    LabeledSlider {
                        label: "  Q";
                        minimum: 0.1;
                        maximum: 18;
                        value: band.q;
                        suffix: "";
                        enabled: root.eq-enabled;
                        changed(val) => {
                            root.eq-band-changed(band-idx, band.band-type-index, band.frequency, band.gain-db, val);
                        }
                    }

                    // Separator between bands
                    Rectangle {
                        height: 1px;
                        background: #333;
                    }
                }

                // --- Gate ---
                SectionHeader { title: "Noise Gate"; }

                CheckBox {
                    text: "Enable Gate";
                    checked: root.gate.enabled;
                    toggled => {
                        root.gate.enabled = self.checked;
                        root.gate-enabled-changed(self.checked);
                    }
                }

                LabeledSlider {
                    label: "Threshold";
                    minimum: -80;
                    maximum: 0;
                    value: root.gate.threshold-db;
                    suffix: " dB";
                    enabled: root.gate.enabled;
                    changed(val) => {
                        root.gate.threshold-db = val;
                        root.gate-changed(val, root.gate.attack-ms, root.gate.release-ms, root.gate.hold-ms);
                    }
                }

                LabeledSlider {
                    label: "Attack";
                    minimum: 0.1;
                    maximum: 100;
                    value: root.gate.attack-ms;
                    suffix: " ms";
                    enabled: root.gate.enabled;
                    changed(val) => {
                        root.gate.attack-ms = val;
                        root.gate-changed(root.gate.threshold-db, val, root.gate.release-ms, root.gate.hold-ms);
                    }
                }

                LabeledSlider {
                    label: "Release";
                    minimum: 1;
                    maximum: 2000;
                    value: root.gate.release-ms;
                    suffix: " ms";
                    enabled: root.gate.enabled;
                    changed(val) => {
                        root.gate.release-ms = val;
                        root.gate-changed(root.gate.threshold-db, root.gate.attack-ms, val, root.gate.hold-ms);
                    }
                }

                LabeledSlider {
                    label: "Hold";
                    minimum: 0;
                    maximum: 500;
                    value: root.gate.hold-ms;
                    suffix: " ms";
                    enabled: root.gate.enabled;
                    changed(val) => {
                        root.gate.hold-ms = val;
                        root.gate-changed(root.gate.threshold-db, root.gate.attack-ms, root.gate.release-ms, val);
                    }
                }

                // --- De-esser ---
                SectionHeader { title: "De-esser"; }

                CheckBox {
                    text: "Enable De-esser";
                    checked: root.deesser.enabled;
                    toggled => {
                        root.deesser.enabled = self.checked;
                        root.deesser-enabled-changed(self.checked);
                    }
                }

                LabeledSlider {
                    label: "Frequency";
                    minimum: 2000;
                    maximum: 16000;
                    value: root.deesser.frequency;
                    suffix: " Hz";
                    enabled: root.deesser.enabled;
                    changed(val) => {
                        root.deesser.frequency = val;
                        root.deesser-changed(val, root.deesser.threshold-db, root.deesser.ratio);
                    }
                }

                LabeledSlider {
                    label: "Threshold";
                    minimum: -60;
                    maximum: 0;
                    value: root.deesser.threshold-db;
                    suffix: " dB";
                    enabled: root.deesser.enabled;
                    changed(val) => {
                        root.deesser.threshold-db = val;
                        root.deesser-changed(root.deesser.frequency, val, root.deesser.ratio);
                    }
                }

                LabeledSlider {
                    label: "Ratio";
                    minimum: 1;
                    maximum: 20;
                    value: root.deesser.ratio;
                    suffix: ":1";
                    enabled: root.deesser.enabled;
                    changed(val) => {
                        root.deesser.ratio = val;
                        root.deesser-changed(root.deesser.frequency, root.deesser.threshold-db, val);
                    }
                }

                // Separator between input and output sections
                Rectangle {
                    height: 2px;
                    background: #555;
                }

                // ===== OUTPUT DSP SECTION =====
                SectionHeader { title: "Output DSP"; }

                HorizontalBox {
                    spacing: 8px;
                    height: 32px;

                    Text {
                        text: "Output:";
                        vertical-alignment: center;
                        width: 60px;
                    }

                    output-combo := ComboBox {
                        model: root.output-names;
                        current-index: root.selected-output-index;
                        selected(val) => {
                            root.selected-output-index = self.current-index;
                            root.output-selected(self.current-index);
                        }
                    }
                }

                // --- Compressor ---
                SectionHeader { title: "Compressor"; }

                CheckBox {
                    text: "Enable Compressor";
                    checked: root.compressor.enabled;
                    toggled => {
                        root.compressor.enabled = self.checked;
                        root.compressor-enabled-changed(self.checked);
                    }
                }

                LabeledSlider {
                    label: "Threshold";
                    minimum: -60;
                    maximum: 0;
                    value: root.compressor.threshold-db;
                    suffix: " dB";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.threshold-db = val;
                        root.compressor-changed(val, root.compressor.ratio, root.compressor.attack-ms, root.compressor.release-ms, root.compressor.makeup-gain-db, root.compressor.knee-db);
                    }
                }

                LabeledSlider {
                    label: "Ratio";
                    minimum: 1;
                    maximum: 20;
                    value: root.compressor.ratio;
                    suffix: ":1";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.ratio = val;
                        root.compressor-changed(root.compressor.threshold-db, val, root.compressor.attack-ms, root.compressor.release-ms, root.compressor.makeup-gain-db, root.compressor.knee-db);
                    }
                }

                LabeledSlider {
                    label: "Attack";
                    minimum: 0.1;
                    maximum: 200;
                    value: root.compressor.attack-ms;
                    suffix: " ms";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.attack-ms = val;
                        root.compressor-changed(root.compressor.threshold-db, root.compressor.ratio, val, root.compressor.release-ms, root.compressor.makeup-gain-db, root.compressor.knee-db);
                    }
                }

                LabeledSlider {
                    label: "Release";
                    minimum: 1;
                    maximum: 2000;
                    value: root.compressor.release-ms;
                    suffix: " ms";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.release-ms = val;
                        root.compressor-changed(root.compressor.threshold-db, root.compressor.ratio, root.compressor.attack-ms, val, root.compressor.makeup-gain-db, root.compressor.knee-db);
                    }
                }

                LabeledSlider {
                    label: "Makeup Gain";
                    minimum: 0;
                    maximum: 30;
                    value: root.compressor.makeup-gain-db;
                    suffix: " dB";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.makeup-gain-db = val;
                        root.compressor-changed(root.compressor.threshold-db, root.compressor.ratio, root.compressor.attack-ms, root.compressor.release-ms, val, root.compressor.knee-db);
                    }
                }

                LabeledSlider {
                    label: "Knee";
                    minimum: 0;
                    maximum: 12;
                    value: root.compressor.knee-db;
                    suffix: " dB";
                    enabled: root.compressor.enabled;
                    changed(val) => {
                        root.compressor.knee-db = val;
                        root.compressor-changed(root.compressor.threshold-db, root.compressor.ratio, root.compressor.attack-ms, root.compressor.release-ms, root.compressor.makeup-gain-db, val);
                    }
                }

                // --- Limiter ---
                SectionHeader { title: "Limiter"; }

                CheckBox {
                    text: "Enable Limiter";
                    checked: root.limiter.enabled;
                    toggled => {
                        root.limiter.enabled = self.checked;
                        root.limiter-enabled-changed(self.checked);
                    }
                }

                LabeledSlider {
                    label: "Ceiling";
                    minimum: -12;
                    maximum: 0;
                    value: root.limiter.ceiling-db;
                    suffix: " dB";
                    enabled: root.limiter.enabled;
                    changed(val) => {
                        root.limiter.ceiling-db = val;
                        root.limiter-changed(val, root.limiter.release-ms);
                    }
                }

                LabeledSlider {
                    label: "Release";
                    minimum: 1;
                    maximum: 500;
                    value: root.limiter.release-ms;
                    suffix: " ms";
                    enabled: root.limiter.enabled;
                    changed(val) => {
                        root.limiter.release-ms = val;
                        root.limiter-changed(root.limiter.ceiling-db, val);
                    }
                }

                // Bottom spacer
                Rectangle {
                    height: 8px;
                }
            }
        }

        // Close button
        HorizontalBox {
            height: 36px;
            Rectangle { horizontal-stretch: 1; }
            Button {
                text: "Close";
                clicked => { root.close-requested(); }
            }
        }
    }
}
