import { Slider, Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct OutputStripData {
    id: int,
    name: string,
    color: color,
    volume: int,
    muted: bool,
    selected: bool,
}

export struct RouteStripData {
    input-id: int,
    output-id: int,
    name: string,
    color: color,
    volume: int,
    muted: bool,
}

export global AppletState {
    in-out property <[OutputStripData]> outputs;
    in-out property <[RouteStripData]> routes;
    in-out property <string> selected-output-name: "(none)";
    in-out property <bool> daemon-connected: false;

    callback set-output-volume(int, int);
    callback set-output-mute(int, bool);
    callback set-route-volume(int, int, int);
    callback set-route-mute(int, int, bool);
    callback select-output(int);
    callback open-mixer();
}

export component PopupWindow inherits Window {
    title: "MixCtl";
    width: 380px;
    no-frame: true;

    if !AppletState.daemon-connected: Rectangle {
        background: #2c3e50ee;

        Text {
            text: "Waiting for daemon...";
            color: #bbb;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    VerticalBox {
        padding: 8px;
        spacing: 4px;

        // Output levels header
        Text {
            text: "Output Levels";
            font-weight: 700;
            font-size: 13px;
        }

        // Output strips
        for out in AppletState.outputs: Rectangle {
            height: 36px;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 6px;

                // Color dot
                Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: out.color;
                    y: (parent.height - self.height) / 2;
                }

                // Name
                Text {
                    text: out.name;
                    width: 80px;
                    vertical-alignment: center;
                    font-size: 12px;
                }

                // Slider
                Slider {
                    horizontal-stretch: 1;
                    minimum: 0;
                    maximum: 100;
                    value: out.volume;
                    changed(val) => {
                        AppletState.set-output-volume(out.id, Math.round(val));
                    }
                }

                // Volume %
                Text {
                    text: out.volume + "%";
                    width: 36px;
                    vertical-alignment: center;
                    font-size: 11px;
                    horizontal-alignment: right;
                }

                // Mute button
                Rectangle {
                    width: 52px;
                    height: 24px;
                    border-radius: 4px;
                    background: out.muted ? #e74c3c : #3498db;

                    TouchArea {
                        clicked => {
                            AppletState.set-output-mute(out.id, !out.muted);
                        }
                    }

                    Text {
                        text: out.muted ? "Unmute" : "Mute";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 10px;
                    }
                }

                // Select button
                Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: 4px;
                    background: out.selected ? #3498db : #555;

                    TouchArea {
                        clicked => {
                            AppletState.select-output(out.id);
                        }
                    }

                    Text {
                        text: "→";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                    }
                }
            }
        }

        // Separator
        Rectangle {
            height: 1px;
            background: #555;
        }

        // Route section header
        Text {
            text: "Input mix for: " + AppletState.selected-output-name;
            font-weight: 700;
            font-size: 13px;
        }

        // Route strips
        for route in AppletState.routes: Rectangle {
            height: 32px;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                spacing: 6px;

                Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: route.color;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: route.name;
                    width: 64px;
                    vertical-alignment: center;
                    font-size: 12px;
                }

                Slider {
                    horizontal-stretch: 1;
                    minimum: 0;
                    maximum: 100;
                    value: route.volume;
                    changed(val) => {
                        AppletState.set-route-volume(route.input-id, route.output-id, Math.round(val));
                    }
                }

                Text {
                    text: route.volume + "%";
                    width: 36px;
                    vertical-alignment: center;
                    font-size: 11px;
                    horizontal-alignment: right;
                }

                Rectangle {
                    width: 52px;
                    height: 24px;
                    border-radius: 4px;
                    background: route.muted ? #e74c3c : #3498db;

                    TouchArea {
                        clicked => {
                            AppletState.set-route-mute(route.input-id, route.output-id, !route.muted);
                        }
                    }

                    Text {
                        text: route.muted ? "Unmute" : "Mute";
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 10px;
                    }
                }
            }
        }

        // Open mixer button
        Button {
            text: "Open Mixer";
            clicked => {
                AppletState.open-mixer();
            }
        }
    }
}
